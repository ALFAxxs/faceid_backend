# === FaceID production sozlamalari ===
# Bu faylni `.env.production` deb nusxalang va qiymatlarni to'ldiring.
# MUHIM: .env.production'ni git'ga qo'shmang (maxfiy ma'lumotlar).

# --- Django ---
DEBUG=False
# Kuchli tasodifiy kalit yarating, masalan:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=BU_YERGA_UZUN_TASODIFIY_KALIT

# Domeningiz va/yoki server IP'si (vergul bilan)
ALLOWED_HOSTS=faceid.example.uz,1.2.3.4
CSRF_TRUSTED_ORIGINS=https://faceid.example.uz
CORS_ALLOWED_ORIGINS=https://faceid.example.uz

# --- Ma'lumotlar bazasi (PostgreSQL, compose ichidagi 'db' servisi) ---
POSTGRES_DB=faceid_db
POSTGRES_USER=faceid
POSTGRES_PASSWORD=KUCHLI_PAROL_QOYING
DATABASE_URL=postgresql://faceid:KUCHLI_PAROL_QOYING@db:5432/faceid_db

# --- Redis (compose ichidagi 'redis' servisi) ---
REDIS_URL=redis://redis:6379/0

# --- ISAPI webhook himoyasi ---
# Qurilma URL'iga shu tokenni qo'shasiz: /api/isapi/event/?device_id=...&token=BU_TOKEN
# Uzun tasodifiy qiymat bering.
ISAPI_WEBHOOK_TOKEN=BU_YERGA_UZUN_TASODIFIY_TOKEN

# --- HTTPS ---
# TLS sertifikat sozlangach True qiling (HTTP -> HTTPS yo'naltirish + HSTS)
SECURE_SSL_REDIRECT=False
